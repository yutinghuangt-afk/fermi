# X (Twitter) credentials
X_USERNAME=your_x_username_or_email
X_PASSWORD=your_x_password
# Optional: 2FA backup code (if 2FA is enabled, the agent will pause and prompt)

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Notion (optional — set to enable Notion export)
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=your_database_id

# Gmail (optional — set to enable email report)
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=your_app_password
GMAIL_RECIPIENT=recipient@example.com

# Agent behaviour
HEADLESS=false          # true = headless browser (may be blocked by X)
SCROLL_COUNT=20         # how many times to scroll the timeline
SCROLL_DELAY=2.0        # seconds between scrolls
MAX_TWEETS=50           # max tweets to collect per run
TARGET_URL=https://x.com/home   # or a search URL, profile URL, etc.
